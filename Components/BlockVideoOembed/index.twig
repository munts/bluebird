<flynt-component name="BlockVideoOembed" load:on="visible" class="componentSpacingNone" {{ options.theme ? 'data-theme="' ~ options.theme ~ '"' }} {% if fn('is_front_page') %} style="" {% endif %}>
{% if fn('is_front_page') %}
  <div class="containerFull frontPage">
    <div class="video-container">
      {% if videoType == 'iframe' and iframeCode %}
        <div class="video-iframe-wrapper">{{ iframeCode|raw }}</div>
      {% else %}
        <video autoplay muted loop playsinline preload="none" fetchpriority="high"{% if posterImage %} poster="{{ posterImage.src }}"{% endif %}{% if posterImageMobile %} data-poster-mobile="{{ posterImageMobile.src }}"{% endif %}{% if oembedMobile %} data-src-mobile="{{ oembedMobile }}"{% endif %}>
          <source src="{{ oembed }}" type="video/mp4">
        </video>
      {% endif %}
    </div>
    <div class="video-overlay" aria-hidden="true"></div>
    {% if eyebrowText or headingText or subtitleText %}
      <div class="tag-line-container">
        {% if eyebrowText %}<p class="eyebrow">{{ eyebrowText }}</p>{% endif %}
        {% if headingText %}<h1 class="heading">{{ headingText }}</h1>{% endif %}
        {% if subtitleText %}<p class="subtitle">{{ subtitleText }}</p>{% endif %}
        {% if ctaPrimaryLabel or ctaSecondaryLabel %}
          <div class="cta-group">
            {% if ctaPrimaryLabel %}
              <a class="cta-btn cta-btn--primary" href="{{ ctaPrimaryUrl }}">
                <i class="fa-solid fa-phone" aria-hidden="true"></i>
                {{ ctaPrimaryLabel }}
              </a>
            {% endif %}
            {% if ctaSecondaryLabel %}
              <a class="cta-btn cta-btn--secondary" href="{{ ctaSecondaryUrl }}">
                {{ ctaSecondaryLabel }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
  {% else %}
  <div class="containerFull">
    <div class="video" data-size="{{ options.size }}" data-align="center">
      {% include 'Partials/_figure.twig' ignore missing with {image: posterImage} only %}
      <div data-ref="videoPlayer" class="video-player">
        {% if videoType == 'iframe' and iframeCode %}
          <div class="video-iframe-wrapper">{{ iframeCode|raw }}</div>
        {% else %}
          <video autoplay muted loop playsinline preload="none" fetchpriority="high"{% if posterImage %} poster="{{ posterImage.src }}"{% endif %}{% if posterImageMobile %} data-poster-mobile="{{ posterImageMobile.src }}"{% endif %}{% if oembedMobile %} data-src-mobile="{{ oembedMobile }}"{% endif %}>
            <source src="{{ oembed }}" type="video/mp4">
          </video>
          <div class="video-loader"></div>
          <button data-ref="playButton" class="video-playButton" type="button" aria-label="Play Video"></button>
        {% endif %}
      </div>
    </div>
    {% if eyebrowText or headingText or subtitleText %}
      <div class="tag-line-container">
        {% if eyebrowText %}<p class="eyebrow">{{ eyebrowText }}</p>{% endif %}
        {% if headingText %}<h1 class="heading">{{ headingText }}</h1>{% endif %}
        {% if subtitleText %}<p class="subtitle">{{ subtitleText }}</p>{% endif %}
        {% if ctaPrimaryLabel or ctaSecondaryLabel %}
          <div class="cta-group">
            {% if ctaPrimaryLabel %}
              <a class="cta-btn cta-btn--primary" href="{{ ctaPrimaryUrl }}">
                <i class="fa-solid fa-phone" aria-hidden="true"></i>
                {{ ctaPrimaryLabel }}
              </a>
            {% endif %}
            {% if ctaSecondaryLabel %}
              <a class="cta-btn cta-btn--secondary" href="{{ ctaSecondaryUrl }}">
                {{ ctaSecondaryLabel }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
  {% endif %}
</flynt-component>
