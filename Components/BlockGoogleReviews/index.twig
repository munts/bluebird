{% if reviews|length > 0 %}
  {% set perPage = jsonData.perPage ?? 12 %}
  {% set totalPages = ((reviews|length) / perPage)|round(0, 'ceil') %}
  <flynt-component name="BlockGoogleReviews" load:on="visible" class="componentSpacing" {{ options.theme ? 'data-theme="' ~ options.theme ~ '"' }}>
    {% if jsonData %}
      <script type="application/json">{{ jsonData|json_encode }}</script>
    {% endif %}
    <div class="container" data-flow="layout">
      {% if preContentHtml %}
        <div data-size="medium" data-align="center" data-text-align="center">
          {{ preContentHtml|e('wp_kses_post') }}
        </div>
      {% endif %}

      {% if overallRating > 0 %}
        <div class="ratingSummary">
          <div class="stars" aria-hidden="true">
            {% for i in 1..5 %}
              {% if i <= overallRating|round %}
                <svg class="starIcon starIcon--filled" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% else %}
                <svg class="starIcon starIcon--empty" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% endif %}
            {% endfor %}
          </div>
          <span class="ratingText">{{ overallRating }} out of 5 based on {{ totalReviewCount }} reviews</span>
        </div>
      {% endif %}

      <ul class="reviewGrid" data-ref="reviewGrid">
        {% for review in reviews %}
          {% set pageNum = ((loop.index - 1) / perPage)|round(0, 'floor') + 1 %}
          <li class="reviewCard boxBorder" data-theme="reset" data-page="{{ pageNum }}" {{ pageNum > 1 ? 'hidden' }}>
            <div class="reviewHeader">
              <div class="reviewerInfo">
                {% if review.profilePhoto %}
                  <img class="reviewerAvatar" src="{{ review.profilePhoto|e('esc_url') }}" alt="" width="40" height="40" loading="lazy">
                {% else %}
                  <span class="reviewerInitial">{{ review.author|first|upper }}</span>
                {% endif %}
                <div class="reviewerMeta">
                  <span class="reviewerName">{{ review.author|e }}</span>
                  {% if review.relativeTime %}
                    <span class="reviewDate">{{ review.relativeTime|e }}</span>
                  {% endif %}
                </div>
              </div>
              <div class="reviewStars" aria-label="{{ review.rating }} out of 5 stars">
                {% for i in 1..5 %}
                  {% if i <= review.rating %}
                    <svg class="starIcon starIcon--filled" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% else %}
                    <svg class="starIcon starIcon--empty" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
            {% if review.text %}
              <div class="reviewBody">
                <p class="reviewText" data-ref="reviewText">{{ review.text|e }}</p>
                {% if review.text|length > 150 %}
                  <button class="expandBtn button--text" data-refs="expandBtn" type="button" aria-expanded="false">
                    Read more
                  </button>
                {% endif %}
              </div>
            {% endif %}
            {% if review.googleMapsUri %}
              <a class="googleLink" href="{{ review.googleMapsUri|e('esc_url') }}" target="_blank" rel="noopener noreferrer">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                View on Google
              </a>
            {% endif %}
          </li>
        {% endfor %}
      </ul>

      {% if totalPages > 1 %}
        <nav class="pagination" data-ref="pagination" aria-label="Reviews pagination">
          <button class="pagination-btn" data-refs="prevBtn" type="button" disabled>
            &larr; Previous
          </button>
          <span class="pagination-info" data-ref="pageInfo">Page 1 of {{ totalPages }}</span>
          <button class="pagination-btn" data-refs="nextBtn" type="button">
            Next &rarr;
          </button>
        </nav>
      {% endif %}
    </div>
  </flynt-component>
{% endif %}
