<ul data-ref="menu" id="navigationBurger-menu" class="menu">
  {% for item in items %}
    <li class="item {{- item.current ? ' current-menu-item' }}{{- item.children ? ' has-children' }}">
      <div class="item-header">
        <a class="link" href="{{ item.link|e('esc_url') }}" {{- item.is_external or item.is_target_blank ? ' target="_blank" rel="noopener noreferrer"' -}}>{{ item.title }}</a>
        {% if item.children %}
          <button class="submenu-toggle" data-ref="submenuToggle" aria-expanded="false" aria-label="Toggle submenu for {{ item.title }}">
            <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
          </button>
        {% endif %}
      </div>
      {% if item.children %}
        <ul class="submenu">
          {% for child in item.children %}
            <li class="submenu-item {{- child.current ? ' current-menu-item' }}">
              <a class="submenu-link" href="{{ child.link|e('esc_url') }}" {{- child.is_external or child.is_target_blank ? ' target="_blank" rel="noopener noreferrer"' -}}>{{ child.title }}</a>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </li>
  {% endfor %}
</ul>
